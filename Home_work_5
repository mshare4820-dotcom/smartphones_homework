<!DOCTYPE html>
<html>

<head>
    <title>Operations</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
        }

        .box {
            width: 80px;
            height: 35px;
            margin: 5px;
            text-align: center;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .row {
            margin-top: 20px;
        }

        .result {
            display: inline-block;
            width: 150px;
            height: 35px;
            border: 2px solid #333;
            margin-left: 15px;
            line-height: 35px;
            text-align: center;
            background-color: #f9f9f9;
            font-weight: bold;
        }

        button {
            width: 100px;
            height: 40px;
            cursor: pointer;
            background-color: #007BFF;
            color: white;
            border: none;
            border-radius: 5px;
        }

        button:hover {
            background-color: #0056b3;
        }
    </style>
</head>

<body>

    <input type="number" id="num1" class="box" placeholder="الرقم 1">
    <input type="number" id="num2" class="box" placeholder="الرقم 2">
    <input type="number" id="num3" class="box" placeholder="الرقم 3">

    <div class="row">
        <button onclick="calculate('add')">الجمع</button>
        <div id="addResult" class="result"></div>
    </div>

    <div class="row">
        <button onclick="calculate('mul')">الضرب</button>
        <div id="mulResult" class="result"></div>
    </div>

    <div class="row">
        <button onclick="calculate('max')">الأكبر</button>
        <div id="maxResult" class="result"></div>
    </div>

    <div class="row">
        <button onclick="calculate('avg')">المتوسط</button>
        <div id="avgResult" class="result"></div>
    </div>

    <script>
        function getValue(id) {
            var val = document.getElementById(id).value;
            return val === "" ? 0 : parseFloat(val);
        }

        function calculate(type) {
            var a = getValue("num1");
            var b = getValue("num2");
            var c = getValue("num3");
            var res = 0;
            var targetId = "";

            if (type === 'add') {
                res = a + b + c;
                targetId = "addResult";
            } else if (type === 'mul') {
                res = a * b * c;
                targetId = "mulResult";
            } else if (type === 'max') {
                res = Math.max(a, b, c);
                targetId = "maxResult";
            } else if (type === 'avg') {
                res = (a + b + c) / 3;
                targetId = "avgResult";
            }

            document.getElementById(targetId).innerHTML = res.toFixed(2);
        }
    </script>

</body>

</html>
